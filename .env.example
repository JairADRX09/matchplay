# Server bind address
SERVER_HOST=0.0.0.0
# Server port
SERVER_PORT=8080
# Card time-to-live in seconds
CARD_TTL_SECS=300
# How often the reaper runs in seconds
REAPER_INTERVAL_SECS=15
# Max PublishCard messages per minute per connection
RATE_LIMIT_CARDS_PER_MIN=2
# Max JoinCard messages per minute per connection
RATE_LIMIT_JOINS_PER_MIN=5
# Maximum concurrent WebSocket connections
MAX_CONNECTIONS=10000
# Log level: trace, debug, info, warn, error
LOG_LEVEL=info
